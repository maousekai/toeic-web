generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Learner {
  id          String        @id @default(cuid())
  name        String?
  targetScore Int?
  userId      String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User?         @relation(fields: [userId], references: [id])
  attempts    TestAttempt[]
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         String    @default("STUDENT")
  image        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  learners     Learner[]
}

model Vocab {
  id           String   @id @default(cuid())
  word         String
  phonetic     String?
  partOfSpeech String
  definition   String
  example      String
  translation  String?
  category     String
  level        String   @default("A1")
  difficulty   Int      @default(1)
  createdAt    DateTime @default(now())
}

model GrammarLesson {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  category  String
  level     String   @default("intermediate")
  summary   String
  content   String
  example   String
  createdAt DateTime @default(now())
}

model GrammarExercise {
  id          String   @id @default(cuid())
  lessonId    String
  question    String
  options     String
  answer      Int
  explanation String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Strategy {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  section   String
  content   String
  createdAt DateTime @default(now())
}

model Question {
  id          String   @id @default(cuid())
  part        Int
  passage     String?
  groupId     String?
  audioScript String?
  imagePrompt String?
  question    String
  options     String
  answer      Int
  explanation String?
  difficulty  Int      @default(2)
  category    String?
  createdAt   DateTime @default(now())
}

model TestSet {
  id          String   @id @default(cuid())
  title       String
  description String
  durationMin Int      @default(40)
  type        String   @default("mini")
  questionIds String
  createdAt   DateTime @default(now())
}

model TestAttempt {
  id               String    @id @default(cuid())
  learnerId        String
  testSetId        String?
  testSetTitle     String?
  type             String
  startedAt        DateTime  @default(now())
  finishedAt       DateTime?
  durationSec      Int?
  answers          String
  totalQuestions   Int       @default(0)
  correctCount     Int       @default(0)
  listeningCorrect Int?
  readingCorrect   Int?
  score            Int?
  listeningScore   Int?
  readingScore     Int?
  learner          Learner   @relation(fields: [learnerId], references: [id])
}
