# ============================================================
#  TOEIC Ace AI — Environment Variables
#  Copy this file to `.env` and fill in your values.
#  NEVER commit the real `.env` file!
# ============================================================

# ---------- DATABASE ----------
# SQLite file path (relative to project root).
# The db/ folder and file will be auto-created on first `prisma db push`.
DATABASE_URL="file:./db/custom.db"

# ---------- AUTH ----------
# Required for NextAuth.js. Generate a random secret:
#   openssl rand -base64 32
# On Windows:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars"

# URL of the deployed app (no trailing slash).
# - Local dev:    http://localhost:3000
# - Vercel:       https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ---------- AI PROVIDER (pick ONE — leave others blank) ----------
# The app auto-detects which provider to use by priority:
#   OLLAMA > OPENAI > OPENROUTER > GROQ > GEMINI > ZAI(fallback)
#
# --- Option 1: Ollama (LOCAL, FREE, 100% offline) ---
# Install:  https://ollama.com/download
# Pull a model:
#   ollama pull qwen2.5:3b    (4GB RAM, fast)
#   ollama pull qwen2.5:7b    (8GB RAM, better quality)
# Start server:
#   ollama serve
OLLAMA_BASE_URL="http://localhost:11434/v1"
OLLAMA_MODEL="qwen2.5:3b"

# --- Option 2: OpenAI (cloud, paid) ---
# Get key: https://platform.openai.com/api-keys
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"

# --- Option 3: ZAI (legacy fallback) ---
# Dành cho hệ thống cũ

# --- Option 4: Groq (cloud, very fast, free tier) ---
# Get key: https://console.groq.com/keys
# GROQ_API_KEY="gsk_..."
# GROQ_MODEL="llama-3.3-70b-versatile"

# --- Option 5: Google Gemini (cloud, generous free tier) ---
# Get key: https://aistudio.google.com/apikey
# GEMINI_API_KEY="AIza..."
# GEMINI_MODEL="gemini-1.5-flash"

# --- Option 6: ZAI (default in Z.ai sandbox, no setup needed) ---
# If none of the above are set, the app falls back to the ZAI SDK.
# This only works inside the Z.ai Code sandbox environment.
